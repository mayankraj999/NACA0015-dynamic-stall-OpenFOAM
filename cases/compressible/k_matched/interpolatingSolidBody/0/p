FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "./initialConditions"

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform $pRef;

boundaryField
{
    aerofoil
    {
        type            zeroGradient;
    }
    inlet
    {
        type            fixedValue;
        value           uniform $pRef;
    }
    outlet
    {
        type            waveTransmissive;
        field           p;
        psi             psi;            // OF12 uses "psi" not "thermo:psi"
        gamma           $gamma;
        fieldInf        $pRef;
        lInf            10;
        value           uniform $pRef;
    }
    back
    {
        type            empty;
    }
    front
    {
        type            empty;
    }
}

