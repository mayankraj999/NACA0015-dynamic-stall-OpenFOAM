forceCoeffs
{
    type            forceCoeffs;
    libs            ("libforces.so");

    writeControl    timeStep;
    writeInterval   1;

    log             yes;

    patches         (aerofoil);

    rho             rhoInf;
    rhoInf          1.17;
    pRef            100000;
    magUInf         173.1;          // Mach 0.5 * sqrt(1.4*287.05*298)
    lRef            1;
    Aref            0.2;            // chord(1m) * span(0.2m extrude) = true 2D reference

    liftDir         (0 0 1);
    dragDir         (1 0 0);
    pitchAxis       (0 1 0);

    CofR            (0.25 0 0);
}

forces
{
    type            forces;
    libs            ("libforces.so");

    writeControl    timeStep;
    writeInterval   1;

    log             yes;

    patches         (aerofoil);

    rho             rhoInf;
    rhoInf          1.17;
    pRef            100000;

    CofR            (0.25 0 0);
}

