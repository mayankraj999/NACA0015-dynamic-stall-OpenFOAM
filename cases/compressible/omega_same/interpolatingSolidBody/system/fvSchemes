FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
    default         Gauss linear;
    grad(p)         Gauss linear;
    grad(U)         Gauss linear;
}

divSchemes
{
    default         none;

    // Momentum
    div(phi,U)      Gauss linearUpwind grad(U);

    // Energy
    div(phi,h)      Gauss linearUpwind default;
    div(phi,K)      Gauss linear;
    div(phi,Ekp)    Gauss linear;

    // Turbulence
    div(phi,k)      Gauss limitedLinear 1;
    div(phi,omega)  Gauss limitedLinear 1;

    // Viscous stress tensor (compressible form)
    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;

    div(phi,(p|rho))    Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear limited corrected 0.5;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method meshWave;
}

