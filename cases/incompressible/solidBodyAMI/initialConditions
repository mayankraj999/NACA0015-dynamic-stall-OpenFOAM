FoamFile
{
    version     2.0;
    format      ascii;
    class       IOobject;
    location    "0";
    object      initialConditions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// simulation controls

np		                     4; // number of processors for parallel computation
iterations                 2; // total number of iterations (to be increases, see NOTES below)
writeEvery              1e-2; // writes down step data every "writeEvery" iterations

// airfoil properties

alpha                      0; // deg - incidence angle
chord                      1; // chord length
CR                   (0 0 0); // center of rotation
pitch                (0 1 0); // pitch axis direction

// fluid properties

mach                    0.05;
Rair                  287.05; // J / (Kg*K)
gamma                    1.4;
Tref                     298; // K
muVal               1.82e-05; // dynamic viscosity
rhoVal                  1.17; // must be consistent with rho = R*T/P (see fields in 0.orig)

// turbulence properties

turbModel          kOmegaSST;
wallFunction nutkWallFunction; // fixedValue (LowRe approach with both k-omegaSST or SA), nutUSpaldingWallFunction (SA);
yPlusControl              72; // z grading
betaOne                0.075; // wilcox beta number
hWall           0.0020029905; // firt cell height Compute as: hWall = Hz / SUM( i from 0 to Nz-1 )( yPlusControl ^ (i / (Nz-1)) )   

/* 

NOTES:

0. to launch type on terminal:
 - ./solution.sh 
 - screen messages from all applications are saved into logs folder instead of being printed on the terminal. Check the checkMesh log file after the meshing process. 

1. for visualization type "paraFoam" in the terminal, then apply, then select the field to visualize. Spurious numerical oscillations appear near transonic conditions (better switch to rhoCentralFoam) 

2. To run the case it must be "cleaned". A suggestion is to copy the "airfoil_default" and work there. Every time a lauch is executed only the following items must be present:
 - 0.orig (directory)
 - constant (directory)
 - system (directory)
 - logs (directory) 
 - initialCOnditions (set up file) 
 - solution.sh (solution file with 1 setUp parameter)

*/


